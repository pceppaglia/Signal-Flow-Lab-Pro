{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!**/.next/cache/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "vocal:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "@rs/constants#build",
        "@rs/utils#build",
        "@rs/ui#build"
      ]
    },
    "signal:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "@rs/constants#build",
        "@rs/utils#build",
        "@rs/ui#build"
      ]
    }
  }
}
