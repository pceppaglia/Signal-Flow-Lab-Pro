// turbo.json
{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!**/.next/cache/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "vocal:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@rs/the-lab-hub#dev"]
    },
    "signal:dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@rs/signal-flow#dev"]
    }
  }
}
